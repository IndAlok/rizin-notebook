{{ $root := .root }}{{ $page := .page }}{{ $nlen := len .unique }}<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Rizin Notebook</title>
    <link rel="stylesheet" href="{{ $root }}static/spectre-icons.min.css">
    <link rel="stylesheet" href="{{ $root }}static/spectre.min.css">
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style type="text/css">
        .spacing-top { margin: 3px 0px 0px 0px !important; }
        .spacing-left { margin: 0px 3px 0px 0px !important; }
        .navbar-fixed-height { height: 32px; }
        .icon-height { height: 20px; }
        iframe { border: 0px; width: 100%; height: 100% }
    </style>
    <script>window.NOTEBOOK_KB={{ keybindings }};</script>
    <script src="{{ $root }}static/shortcuts.js"></script>
    <script type="text/javascript">
      function confirm_delete(event) {
        if (!window.confirm("Are you sure you want to delete it?")) {
          event.preventDefault();
        }
      }
      function verify(event) {
        var title = document.getElementById('title').value.trim().length;
        if (title < 1) {
          alert("Title field is empty. Please add one.");
          event.preventDefault();
        }
      }
      document.addEventListener('DOMContentLoaded', function() {
        NotebookShortcuts.annotate(document.getElementById('nav-about'), 'about');
        NotebookShortcuts.annotate(document.getElementById('save-page'), 'save');
        NotebookShortcuts.bind([
          { action: 'about', handler: function() { document.getElementById('nav-about').click(); } },
          { action: 'new_page', handler: function() { window.location.href = '{{ $root }}new'; } },
          { action: 'save', allowInInputs: true, handler: function() { document.getElementById('save-page').click(); } },
          { action: 'cancel', handler: function() { document.getElementById('cancel-page').click(); } }
        ]);
      });
    </script>
  </head>
<body>
  <section class="container grid-960 mt-10">
    <header class="navbar navbar-fixed-height">
      <section class="navbar-section">
        <img src="{{ $root }}static/logo.png" width="30" height="30" />&nbsp;
        <a href="{{ $root }}" class="navbar-brand mr-10">Rizin Notebook</a>
      </section>
      <section class="navbar-section">
        <a href="{{ $root }}about" class="btn" id="nav-about">About</a>
        &nbsp;
        {{ $page.title }}
      </section>
    </header>
    <section class="container">
      <div class="columns">
        <div class="column">
          <form action="{{ $root }}edit" method="POST" enctype="multipart/form-data" onsubmit="verify(event)">
            <div class="form-group">
              <input type="hidden" name="unique" value="{{ .unique }}" />
              <input type="text" class="form-input" name="title" id="title" value="{{ .title }}" placeholder="Notebook page title"/>
              <br>
              <label for="binary">{{ if lt $nlen 1 }}Optional binary to open{{ else }}Attach or replace binary{{ end }}: </label>
              <input type="file" id="binary" name="binary">
              {{ if gt $nlen 0 }}
              <p class="form-input-hint">Current binary: {{ if $page.filename }}{{ $page.filename }}{{ else }}none attached{{ end }}</p>
              {{ else }}
              <p class="form-input-hint">You can create notes without a binary now and attach one later from the edit page.</p>
              {{ end }}
            </div>
            <div class="form-group">
              <button class="btn btn-primary" type="submit" id="save-page">{{ if lt $nlen 1 }}Create{{ else }}Save{{ end }}</button>
              <a class="btn" href="{{ $root }}" id="cancel-page">Cancel</a>
              {{ if gt $nlen 0 }}
              <a class="btn float-right" href="{{ $root }}delete/{{ .unique }}" onclick="confirm_delete(event)">Delete</a>
              {{ end }}
            </div>
          </form>
        </div>
      </div>
    </section>
  </section>
</body>
</html>