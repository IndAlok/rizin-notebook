{{ $root := .root }}{{ $eklen := len .editkey }}<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Rizin Notebook</title>
    <link rel="stylesheet" href="{{ $root }}static/spectre-icons.min.css">
    <link rel="stylesheet" href="{{ $root }}static/spectre.min.css">
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style type="text/css">
        .spacing-top { margin: 3px 0px 0px 0px !important; }
        .spacing-left { margin: 0px 3px 0px 0px !important; }
        .navbar-fixed-height { height: 32px; }
        .inline { display: inline; }
        .icon-height { height: 20px; }
        iframe { border: 0px; width: 100%; height: 100% }
    </style>
      <script>window.NOTEBOOK_KB={{ keybindings }};</script>
      <script src="{{ $root }}static/shortcuts.js"></script>
    <script type="text/javascript">
{{ if eq .action "environment" }}
      function confirm_delete(event) {
        if (!window.confirm("Are you sure you want to delete it?")) {
          event.preventDefault();
          return;
        }
        document.getElementById('subaction').value = "delete";
      }
      function verify(event) {
        var key = document.getElementById('key').value.trim().length;
        if (key < 1) {
          alert("Environment Variable Name field is empty.");
          event.preventDefault();
        }
      }
{{ else if eq .action "keybinding" }}
      function verify(event) {
        var value = document.getElementById('value').value.trim();
        if (value.length < 1) {
          alert("Shortcut combo cannot be empty.");
          event.preventDefault();
        }
      }
      function startRecording() {
        var btn = document.getElementById('record-btn');
        var input = document.getElementById('value');
        btn.textContent = 'Press a key combo...';
        btn.classList.add('btn-error');
        input.value = '';
        input.placeholder = 'Press keys now...';
        NotebookShortcuts.record(function(combo) {
          input.value = combo;
          btn.textContent = 'Record';
          btn.classList.remove('btn-error');
          input.placeholder = 'e.g. alt+n, ctrl+s, ctrl+enter';
        });
      }
{{ else if eq .action "autocomplete" }}
      function verify(event) {
        var raw = document.getElementById('value').value.trim();
        var val = parseInt(raw, 10);
        if (isNaN(val) || raw.length < 1) {
          alert("Please enter a valid number.");
          event.preventDefault();
          return;
        }
        if (val < 1) {
          alert("Value must be at least 1.");
          event.preventDefault();
          return;
        }
        if (val > 100) {
          alert("Value must be at most 100.");
          event.preventDefault();
          return;
        }
      }
{{ else if eq .action "search" }}
      function verify(event) {
        if ("{{ .input_type }}" !== "number") {
          return;
        }
        var raw = document.getElementById('value').value.trim();
        var val = parseInt(raw, 10);
        if (isNaN(val) || raw.length < 1) {
          alert("Please enter a valid number.");
          event.preventDefault();
          return;
        }
        if (val < {{ .min_value }}) {
          alert("Value must be at least {{ .min_value }}.");
          event.preventDefault();
          return;
        }
        if (val > {{ .max_value }}) {
          alert("Value must be at most {{ .max_value }}.");
          event.preventDefault();
          return;
        }
      }
{{ else }}
      function verify(event) {}
{{ end }}
      document.addEventListener('DOMContentLoaded', function() {
        NotebookShortcuts.annotate(document.getElementById('nav-home'), 'cancel');
        NotebookShortcuts.annotate(document.getElementById('nav-about'), 'about');
        NotebookShortcuts.annotate(document.getElementById('save-settings'), 'save');
        NotebookShortcuts.bind([
          { action: 'about', handler: function() { document.getElementById('nav-about').click(); } },
          { action: 'new_page', handler: function() { window.location.href = '{{ $root }}new'; } },
          { action: 'save', allowInInputs: true, handler: function() { document.getElementById('save-settings').click(); } },
          { action: 'cancel', handler: function() { document.getElementById('nav-home').click(); } }
        ]);
        var labels = document.querySelectorAll('[data-shortcut-label]');
        for (var i = 0; i < labels.length; i++) {
          labels[i].textContent = NotebookShortcuts.formatCombo(labels[i].getAttribute('data-shortcut-label'));
        }
      });
    </script>
  </head>
<body>
  <section class="container grid-960 mt-10">
    <header class="navbar navbar-fixed-height">
      <section class="navbar-section">
        <img src="{{ $root }}static/logo.png" width="30" height="30" />&nbsp;
        <a href="{{ $root }}" class="navbar-brand mr-10">Rizin Notebook</a>
      </section>
      <section class="navbar-section">
        <a href="{{ $root }}about" class="btn" id="nav-about">About</a>
        &nbsp;
        Edit Settings
        &nbsp;
        <a href="{{ $root }}settings" class="btn btn-primary" id="nav-home">Go Back</a>
      </section>
    </header>
    <section class="container">
      <div class="columns">
        <div class="column">
          <form action="{{ $root }}settings" method="POST" enctype="multipart/form-data" onsubmit="verify(event)">
            <div class="form-group">
              <input type="hidden" name="action" value="{{ .action }}" />
              {{ if eq .action "environment" }}
              <input type="hidden" name="editkey" value="{{ .editkey }}" />
              <input type="hidden" name="subaction" id="subaction" value="{{ if eq $eklen 0 }}new{{ else }}edit{{ end }}" />
              <label class="form-label" for="key">Environment Variable Name</label>
              <input type="text" class="form-input" name="key" id="key" value="{{ .editkey }}" placeholder="Environment Variable Name"/>
              <label class="form-label" for="value">Value</label>
              <input type="text" class="form-input" name="value" id="value" value="{{ if gt $eklen 0 }}{{ index .data .editkey }}{{ end }}" placeholder="Insert a variable value (or leave it empty)"/>
              {{ else if eq .action "keybinding" }}
              <input type="hidden" name="editkey" value="{{ .editkey }}" />
              <input type="hidden" name="subaction" id="subaction" value="save" />
              <label class="form-label">Action: <strong>{{ .label }}</strong></label>
              <label class="form-label" for="value">Keyboard Shortcut</label>
              <div class="input-group">
                <input type="text" class="form-input" name="value" id="value" value="{{ .combo }}" placeholder="e.g. alt+n, ctrl+s, ctrl+enter" />
                <button class="btn input-group-btn" type="button" id="record-btn" onclick="startRecording()">Record</button>
              </div>
              <p class="form-input-hint">Default: <code data-shortcut-label="{{ .default_combo }}"></code> &mdash; Type a combo like <code>alt+n</code> or click Record and press keys.</p>
              {{ else if eq .action "autocomplete" }}
              <input type="hidden" name="editkey" value="{{ .editkey }}" />
              <input type="hidden" name="subaction" id="subaction" value="save" />
              <label class="form-label">Setting: <strong>{{ .label }}</strong></label>
              <label class="form-label" for="value">Value</label>
              <input type="number" class="form-input" name="value" id="value" value="{{ .current_value }}" min="1" max="100" placeholder="Enter a number (1-100)" />
              <p class="form-input-hint">Default: <code>{{ .default_value }}</code> &mdash; Enter a number between 1 and 100.</p>
              {{ else if eq .action "search" }}
              <input type="hidden" name="editkey" value="{{ .editkey }}" />
              <input type="hidden" name="subaction" id="subaction" value="save" />
              <label class="form-label">Setting: <strong>{{ .label }}</strong></label>
              <label class="form-label" for="value">Value</label>
              {{ if eq .input_type "number" }}
              <input type="number" class="form-input" name="value" id="value" value="{{ .current_value }}" min="{{ .min_value }}" max="{{ .max_value }}" placeholder="Enter a number ({{ .min_value }}-{{ .max_value }})" />
              {{ else }}
              <select class="form-select" name="value" id="value">
{{ range $i, $option := .options }}
                <option value="{{ index $option "value" }}"{{ if eq $.current_value (index $option "value") }} selected{{ end }}>{{ index $option "label" }}</option>
{{ end }}
              </select>
              {{ end }}
              <p class="form-input-hint">Default: <code>{{ .default_display }}</code></p>
              {{ end }}
            </div>
            <div class="form-group">
              <button class="btn btn-primary" type="submit" id="save-settings">{{ if eq .action "keybinding" }}Save{{ else if lt $eklen 1 }}Create{{ else }}Save{{ end }}</button>
              {{ if eq .action "environment" }}
              {{ if gt $eklen 0 }}
              <a class="btn" href="{{ $root }}settings">Cancel</a>
              <button class="btn float-right" type="submit" onclick="confirm_delete(event)">Delete</button>
              {{ else }}
              <a class="btn" href="{{ $root }}settings">Cancel</a>
              {{ end }}
              {{ else if eq .action "keybinding" }}
              <a class="btn" href="{{ $root }}settings">Cancel</a>
              <button class="btn float-right" type="button" onclick="document.getElementById('subaction').value='reset';this.form.submit()">Reset to Default</button>
              {{ else if eq .action "autocomplete" }}
              <a class="btn" href="{{ $root }}settings">Cancel</a>
              <button class="btn float-right" type="button" onclick="document.getElementById('subaction').value='reset';this.form.submit()">Reset to Default</button>
              {{ else if eq .action "search" }}
              <a class="btn" href="{{ $root }}settings">Cancel</a>
              <button class="btn float-right" type="button" onclick="document.getElementById('subaction').value='reset';this.form.submit()">Reset to Default</button>
              {{ else }}
              <button class="btn float-right" type="submit">Cancel</button>
              {{ end }}
            </div>
          </form>
        </div>
      </div>
    </section>
  </section>
</body>
</html>
